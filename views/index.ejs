<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Grimoire - Liste</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="topbar">
        <a href="/" class="back-link">← Accueil</a>
        <div class="topbar-right">
            <span class="user-badge">👤 <%= user.username %></span>
            <a href="/favorites" class="fav-link">⭐ Mes Favoris</a>
            <a href="/logout" class="logout-btn">Déconnexion</a>
        </div>
    </div>

    <div class="page-header"><h1>📜 Grimoire des Objets Magiques</h1></div>

    <div class="search-container">
        <input type="text" id="searchInput" placeholder="Chercher un objet..." onkeyup="filterItems()">
    </div>

    <ul id="itemList">
        <% items.forEach(item => { %>
            <li class="item-card">
                <a href="/item/<%= item.index %>" class="item-card-link">
                    <span class="item-name"><%= item.name %></span>
                </a>
                <button class="fav-btn" onclick="addFav('<%= item.index %>', this)">⭐</button>
            </li>
        <% }); %>
    </ul>

    <script>
        function filterItems() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('.item-card').forEach(card => {
                const name = card.querySelector('.item-name').innerText.toLowerCase();
                card.style.display = name.includes(input) ? "flex" : "none";
            });
        }

        async function addFav(index, btn) {
            const res = await fetch(`/api/favorites/${index}`, { method: 'POST' });
            if (res.ok) {
                btn.textContent = '✅';
                btn.disabled = true;
            }
        }
    </script>
</body>
</html>